# ============================================================
# SkillPointe Match — Environment Variables
# Copy this file to .env.local (web) or .env (api) and fill in real values.
# Never commit files containing real secrets.
# ============================================================

# ----------------------------
# Supabase
# ----------------------------
# Get these from your Supabase project dashboard or `supabase status` for local
NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ----------------------------
# Redis
# ----------------------------
REDIS_URL=redis://localhost:6379

# ----------------------------
# Application
# ----------------------------
APP_ENV=local
# local | test | staging | production

NEXT_PUBLIC_API_URL=http://localhost:8000
API_URL=http://localhost:8000

# ----------------------------
# LLM
# ----------------------------
OPENAI_API_KEY=your-openai-api-key
# or ANTHROPIC_API_KEY=your-anthropic-api-key
LLM_MODEL=gpt-4o
LLM_EXTRACTION_MODEL=gpt-4o-mini

# ----------------------------
# Sentry (observability)
# ----------------------------
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ----------------------------
# JWT (app-level, if needed in addition to Supabase JWTs)
# ----------------------------
JWT_SECRET=your-app-jwt-secret

# ----------------------------
# Storage (Supabase Storage)
# ----------------------------
STORAGE_BUCKET_RESUMES=resumes
STORAGE_BUCKET_DOCUMENTS=documents

# ----------------------------
# Feature flags (mirrors SCORING_CONFIG.yaml feature_flags)
# ----------------------------
FEATURE_APPLICANT_SELF_SIGNUP=true
FEATURE_EMPLOYER_INVITE_ONLY=true
FEATURE_DIRECT_MESSAGING=false
FEATURE_APPLICANT_CHAT=true
FEATURE_ADMIN_POLICY_EDITOR=true
