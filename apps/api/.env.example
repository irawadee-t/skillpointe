# Copy to .env — FastAPI backend env vars
# Run `supabase status` after `supabase start` to get local Supabase values

APP_ENV=local
# local | test | staging | production

# Supabase
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# Redis
REDIS_URL=redis://localhost:6379

# LLM
OPENAI_API_KEY=your-openai-api-key
LLM_MODEL=gpt-4o
LLM_EXTRACTION_MODEL=gpt-4o-mini

# Sentry
SENTRY_DSN=

# Storage
STORAGE_BUCKET_RESUMES=resumes
STORAGE_BUCKET_DOCUMENTS=documents

# CORS — comma-separated origins
CORS_ORIGINS=http://localhost:3000
